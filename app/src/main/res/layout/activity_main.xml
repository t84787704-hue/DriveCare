package com.drivecare.app

import android.content.Intent
import android.os.Bundle
import android.widget.Button
import android.widget.Toast
import androidx.appcompat.app.AppCompatActivity

class MainActivity : AppCompatActivity() {

    private lateinit var btnMyVehicles: Button
    private lateinit var btnServiceReminder: Button
    private lateinit var btnFuelTracker: Button
    private lateinit var btnMaintenance: Button
    private lateinit var btnDocuments: Button
    private lateinit var btnEmergency: Button
    private lateinit var btnNotifications: Button
    private lateinit var btnSettings: Button

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)

        setContentView(R.layout.activity_main)


        btnMyVehicles =
            findViewById(R.id.btnMyVehicles)

        btnServiceReminder =
            findViewById(R.id.btnServiceReminder)

        btnFuelTracker =
            findViewById(R.id.btnFuelTracker)

        btnMaintenance =
            findViewById(R.id.btnMaintenance)

        btnDocuments =
            findViewById(R.id.btnDocuments)

        btnEmergency =
            findViewById(R.id.btnEmergency)

        btnNotifications =
            findViewById(R.id.btnNotifications)

        btnSettings =
            findViewById(R.id.btnSettings)



        // My Vehicles

        btnMyVehicles.setOnClickListener {

            startActivity(
                Intent(
                    this,
                    VehicleListActivity::class.java
                )
            )

        }



        // Service Reminder

        btnServiceReminder.setOnClickListener {

            startActivity(
                Intent(
                    this,
                    ReminderListActivity::class.java
                )
            )

        }



        // Fuel Tracker

        btnFuelTracker.setOnClickListener {

            startActivity(
                Intent(
                    this,
                    FuelListActivity::class.java
                )
            )

        }



        // Maintenance History

        btnMaintenance.setOnClickListener {

            Toast.makeText(
                this,
                "Maintenance History Coming Soon.",
                Toast.LENGTH_SHORT
            ).show()

        }



        // Vehicle Documents

        btnDocuments.setOnClickListener {

            Toast.makeText(
                this,
                "Vehicle Documents Coming Soon.",
                Toast.LENGTH_SHORT
            ).show()

        }



        // Emergency Contacts

        btnEmergency.setOnClickListener {

            Toast.makeText(
                this,
                "Emergency Contacts Coming Soon.",
                Toast.LENGTH_SHORT
            ).show()

        }



        // Notifications

        btnNotifications.setOnClickListener {

            Toast.makeText(
                this,
                "Notifications Coming Soon.",
                Toast.LENGTH_SHORT
            ).show()

        }



        // Settings

        btnSettings.setOnClickListener {

            Toast.makeText(
                this,
                "Settings Coming Soon.",
                Toast.LENGTH_SHORT
            ).show()

        }

    }
}