<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Service Reminder"
            android:textSize="28sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etVehicleName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Vehicle Name" />

        <EditText
            android:id="@+id/etReminderTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Reminder Title" />

        <EditText
            android:id="@+id/etReminderType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Reminder Type" />

        <EditText
            android:id="@+id/etDueDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Due Date (DD-MM-YYYY)" />

        <EditText
            android:id="@+id/etCurrentOdometer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Current Odometer" />

        <EditText
            android:id="@+id/etNextServiceOdometer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Next Service Odometer" />

        <EditText
            android:id="@+id/etNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Notes" />

        <Button
            android:id="@+id/btnSaveReminder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Reminder" />

    </LinearLayout>

</ScrollView>